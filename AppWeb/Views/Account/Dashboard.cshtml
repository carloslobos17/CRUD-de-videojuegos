<script>
	function cargarGrafica (categoria=""){
		$.get('Account/obtenerDatos', {categoria:categoria}, function(data){
			var categorias = data.map(x => x.Categoria);
			var totales = data.map(x => x.Total);

			Highcharts.chart('container',{
				chart: {type: 'column'},
				title: {Text: 'Cantidad de videojuegos por categorias en empresa sa de sv'},
				xAxis: {categories: categoria},
				series: [{
					name : 'Juegos',
					data: totales
				}]	
			});
		}
	}


	cargarGrafica();
	$('#filtroCategoria').change(function(){
		cargarGrafica($(this).val());
	})
</script>
</html>