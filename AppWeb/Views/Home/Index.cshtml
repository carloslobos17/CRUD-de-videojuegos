@model IEnumerable<AppWeb.Models.Videojuego>
@{
    ViewData["Title"] = "Videojuegos";
}

<div class="container mt-5">
    <div class="row text-center mb-5">

        <!-- CATEGORÍAS -->
        <div class="col-md-3 mb-3">
            <div class="feature-card">
                <i class="fas fa-gamepad"></i>
                <h5>Categorías</h5>
                <p>Explora por tipo de juego</p>
            </div>
        </div>

        <!-- MÁS VENDIDOS -->
        <div class="col-md-3 mb-3">
            <div class="feature-card">
                <i class="fas fa-fire"></i>
                <h5>Más Vendidos</h5>
                <p>Los juegos más populares</p>
            </div>
        </div>

        <!-- NUEVOS -->
        <div class="col-md-3 mb-3">
            <div class="feature-card">
                <i class="fas fa-star"></i>
                <h5>Nuevos Juegos</h5>
                <p>Lo último en la tienda</p>
            </div>
        </div>

        <!-- PROMOCIONES -->
        <div class="col-md-3 mb-3">
            <div class="feature-card">
                <i class="fas fa-tags"></i>
                <h5>Promociones</h5>
                <p>Ofertas especiales</p>
            </div>
        </div>

    </div>


    <h2 class="text-center fw-bold mb-4" style="color: #FFD700;"> Videojuegos Disponibles</h2>
    <div class="row g-4">
        @foreach (var juego in Model)
        {

            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card game-card h-100">

                    <!-- 🔴 BADGE SUPERIOR -->
                    <div class="badge-top">+12</div>

                    <!-- ❤️ FAVORITO -->
                    <div class="favorite">
                        <i class="fa-regular fa-heart"></i>
                    </div>

                    <!-- IMAGEN -->
                    <img src="@juego.imagen"
                         class="card-img-top game-img" />

                    <div class="card-body d-flex flex-column">

                        <!-- TÍTULO -->
                        <h5 class="card-title fw-bold">
                            @juego.Titulo
                        </h5>


                        <!-- PRECIO -->
                        <h4 class="price mt-2">
                            $@juego.Precio
                        </h4>

                        <!-- CATEGORÍA -->
                        <div class="d-flex align-items-center mt-auto">
                            <i class="fa-solid fa-gamepad me-2 text-warning"></i>

                            <span class="text-muted">@juego.Categoria</span>


                        </div>
                        <div class="paypal-button-container"
                             data-id="@juego.Id"
                             data-titulo="@juego.Titulo"
                             data-precio="@juego.Precio.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <script src="https://www.paypal.com/sdk/js?client-id=Adx2MCRWqlKiJ4I7Uuu5YixVz3Iy3xtVo4aIarFy0LL0dtyoXQbAeXsZZL1WgZpkPPBuyEqbgy4O2HVf&currency=USD&components=buttons">
    </script>

    <script>
        // Seleccionamos todos los contenedores de botones
        document.querySelectorAll('.paypal-button-container').forEach(function(container) {

            // Obtenemos los datos desde los atributos data-
            const idJuego = container.getAttribute('data-id');
            const precio = container.getAttribute('data-precio');
            const titulo = container.getAttribute('data-titulo');

            paypal.Buttons({
                createOrder: function(data, actions) {
                    return actions.order.create({
                        purchase_units: [{
                            description: titulo,
                            amount: {
                                value: precio // Monto dinámico por juego
                            }
                        }]
                    });
                },
        onApprove: function(data, actions) {
            const datosPago = new URLSearchParams();
            datosPago.append('orderId', data.orderID);
            datosPago.append('juegoId', idJuego);

            return fetch('/PayPal/ConfirmarPago', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: datosPago
            })
            .then(async response => {
                if (response.ok) {
                    alert('¡Pago procesado con éxito!');
                    window.location.href = "/"; // Redirigir a inicio
                } else {
                    const err = await response.json();
                    console.error("Error detallado:", err);
                    alert('Error en el servidor: ' + (err.error || 'Desconocido'));
                }
            })
            .catch(error => {
                console.error('Error de red:', error);
                alert('Hubo un problema de conexión con el servidor.');
            });
        }
        // ...
            }).render(container); // Renderiza el botón dentro del div actual
        });
    </script>
